# Configurações do Backend (NestJS)

# Porta do servidor
# - Produção (Render): usar variável de ambiente do Render
# - Desenvolvimento: 3000
PORT=3000

# Banco de dados
DATABASE_URL=postgresql://user:password@localhost:5432/database

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# CORS Origin (opcional, pode usar origem específica ou *)
CORS_ORIGIN=*

# Ambiente
NODE_ENV=development
